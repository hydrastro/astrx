Optional Appendix: PSR-3 adapter sink (non-normative)
<?php
declare(strict_types=1);

namespace Psr\ResultDiagnostics\Extras;

use Psr\Log\LoggerInterface;
use Psr\Log\LogLevel;
use Psr\ResultDiagnostics\Diagnostic;
use Psr\ResultDiagnostics\DiagnosticSink;
use Psr\ResultDiagnostics\Diagnostics;
use Psr\ResultDiagnostics\Level;

interface DiagnosticFormatter
{
    public function format(Diagnostic $d): string;
}

final class Psr3Sink implements DiagnosticSink
{
    public function __construct(
        private LoggerInterface $logger,
        private DiagnosticFormatter $formatter
    ) {}

    public function emit(Diagnostic $d): void
    {
        $this->logger->log(
            self::toPsrLevel($d->level()),
            $this->formatter->format($d),
            $d->context() + ['id' => $d->id()]
        );
    }

    public function emitAll(Diagnostics $diagnostics): void
    {
        foreach ($diagnostics as $d) {
            $this->emit($d);
        }
    }

    private static function toPsrLevel(Level $l): string
    {
        return match ($l) {
            Level::DEBUG => LogLevel::DEBUG,
            Level::INFO => LogLevel::INFO,
            Level::NOTICE => LogLevel::NOTICE,
            Level::WARNING => LogLevel::WARNING,
            Level::ERROR => LogLevel::ERROR,
            Level::CRITICAL => LogLevel::CRITICAL,
            Level::ALERT => LogLevel::ALERT,
            Level::EMERGENCY => LogLevel::EMERGENCY,
        };
    }
}

Examples (non-normative)
Example A: internal composition, drain at boundary once
use Psr\ResultDiagnostics\Result;

$result = $service->handle($request);   // returns Result<Response>

// Boundary emission
$result->drainTo($sink);

if (!$result->isOk()) {
    return errorResponse($result->error());
}

return $result->unwrap();

Example B: deterministic diagnostics merge
$r = openFile($path)            // Result<File>
    ->andThen(fn($f) => parse($f))   // Result<Ast>
    ->andThen(fn($ast) => validate($ast)); // Result<Ast>

foreach ($r->diagnostics() as $d) {
    // warnings, notices, etc.
}
